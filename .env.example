PORT=7000
DATABASE_URL="postgres://user:password@host:port/database?sslmode=require"
JWT_SECRET="generate-a-long-random-secret-here"
CORS_ORIGIN="http://localhost:5173"

# Aiven Postgres CA certificate (contents of ca.pem), needed only in
# environments where backend/ca.pem isn't present on disk (e.g. deploying
# straight from a git checkout, since ca.pem is gitignored). Paste the
# full PEM contents, including the BEGIN/END CERTIFICATE lines.
# DATABASE_CA_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
