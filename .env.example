PORT=7000
DATABASE_URL="postgres://user:password@host:port/database?sslmode=require"
JWT_SECRET="generate-a-long-random-secret-here"
CORS_ORIGIN="http://localhost:5173"

# Aiven Postgres CA certificate (contents of ca.pem), needed only in
# environments where backend/ca.pem isn't present on disk (e.g. deploying
# straight from a git checkout, since ca.pem is gitignored). Paste the
# full PEM contents, including the BEGIN/END CERTIFICATE lines.
# DATABASE_CA_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"

# Used to send "forgot password" reset emails via Gmail SMTP. SMTP_EMAIL is
# the sending Gmail address; SMTP_APP_PASSWORD is a 16-character App Password
# generated at https://myaccount.google.com/apppasswords (requires 2-Step
# Verification enabled on that Google account) — NOT your normal Gmail password.
SMTP_EMAIL="youraddress@gmail.com"
SMTP_APP_PASSWORD="xxxx xxxx xxxx xxxx"

# Base URL of the deployed frontend, used to build the link inside reset emails.
FRONTEND_URL="http://localhost:5173"
